	"authors": [
		"kaelith"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/aureon",
		"sources": "https://github.com/kaelithlol/aureon"
	},
	"license": "CC0-1.0",
	"icon": "assets/aureon/icon.png",
